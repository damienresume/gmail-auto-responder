# ============================================================================
# Gmail Auto-Responder - Environment Variables
# ============================================================================
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Replace placeholder values below with your own
#   3. NEVER commit your .env file to version control
# ============================================================================

# --------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------
APP_NAME="Gmail Auto-Responder"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=

# --------------------------------------------------------------------------
# Database (PostgreSQL)
# Choose your own password. PostgreSQL reads this on first launch only.
# To change later: docker compose down -v && docker compose up -d
# --------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gmail_autoresponder
DB_USERNAME=app_user
DB_PASSWORD=change_me

# --------------------------------------------------------------------------
# Redis (Queue + Cache)
# --------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --------------------------------------------------------------------------
# Queue & Cache Drivers
# --------------------------------------------------------------------------
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# --------------------------------------------------------------------------
# LLM Provider
# Options: groq, ollama, stub
# - groq:   Free cloud inference. Set GROQ_API_KEY below.
# - ollama: Local inference via Docker. No key needed. Requires ~8GB RAM.
# - stub:   Mock responses. No LLM needed. Use for code review.
# --------------------------------------------------------------------------
LLM_PROVIDER=stub
LLM_MODEL=llama-3.1-8b

# Groq (required if LLM_PROVIDER=groq)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1

# Ollama (only if LLM_PROVIDER=ollama)
OLLAMA_HOST=http://ollama:11434

# --------------------------------------------------------------------------
# Google OAuth (required for Gmail features)
# See README "How to get Google OAuth credentials" for setup steps.
# --------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --------------------------------------------------------------------------
# Google Pub/Sub (optional - for real-time push notifications)
# If not configured, the app falls back to polling every 60 seconds.
# --------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_PUBSUB_TOPIC=gmail-notifications
GOOGLE_PUBSUB_SUBSCRIPTION=gmail-push

# --------------------------------------------------------------------------
# Laravel Horizon
# --------------------------------------------------------------------------
HORIZON_PREFIX=gmail-autoresponder:

# --------------------------------------------------------------------------
# Frontend URL (for CORS)
# --------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
